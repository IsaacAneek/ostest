{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "QEMU Kernel Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/full_kernel.elf",
            "miDebuggerServerAddress": "localhost:1234",
            "miDebuggerPath": "/usr/bin/gdb",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "targetArchitecture": "x86",
            "preLaunchTask": "Run QEMU",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set architecture compatibility mode",
                    "text": "set architecture i386:x86-64",
                    "ignoreFailures": false
                },
                {
                    "description": "Load the ELF symbols first",
                    "text": "file ${workspaceFolder}/build/full_kernel.elf",
                    "ignoreFailures": false
                }
            ],
            "logging": {"engineLogging": true}
        }
    ]
}